{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "{{blockNamespace}}/{{blockSlug}}",
    "version": "1.0.0",
    "title": "{{blockTitle}}",
    "category": "{{blockCategory}}",
    "icon": "{{blockIcon}}",
    "description": "{{blockDescription}}",
    "textdomain": "{{textDomain}}",
    "supports": {
        "html": false,
        "align": true
    },
    "attributes": {},
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}
