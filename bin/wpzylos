use WPZylos\Framework\Cli\DevTool\Commands\MakeServiceCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeSettingsCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeShortcodeCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeSubscriberCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeTaxonomyCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeTestCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeTraitCommand;
