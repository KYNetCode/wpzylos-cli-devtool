#!/usr/bin/env php
<?php

/**
 * WPZylos CLI Tool
 *
 * Scaffolds plugins and generates files outside WP runtime.
 */

// Find autoloader
$autoLoaders = [
    // When installed as a dependency (via vendor/bin)
        dirname( __DIR__, 3 ) . '/autoload.php',
    // Local development
        dirname( __DIR__ ) . '/vendor/autoload.php',
];

$autoloaderFound = false;
foreach ( $autoLoaders as $autoloader ) {
    if ( file_exists( $autoloader ) ) {
        require $autoloader;
        $autoloaderFound = true;
        break;
    }
}

if ( ! $autoloaderFound ) {
    fwrite( STDERR, "Autoloader not found. Run: composer install\n" );
    exit( 1 );
}

use WPZylos\Framework\Cli\DevTool\Application;
use WPZylos\Framework\Cli\DevTool\Commands\MakeActionCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeAjaxCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeAssetCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeBlockCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeCastCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeColumnsCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeCommandCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeConfigCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeControllerCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeCronCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeEnumCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeEventCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeExceptionCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeFactoryCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeFilterCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeInterfaceCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeJobCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeListenerCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeMailCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeMenuCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeMetaboxCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeMiddlewareCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeMigrationCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeModelCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeNotificationCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeObserverCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakePolicyCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakePostTypeCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeProviderCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeRequestCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeResourceCommand;
use WPZylos\Framework\Cli\DevTool\Commands\MakeRestCommand;
