// ─── Foundation Commands ─────────────────────────────────────────────────────

// ─── Console Commands ────────────────────────────────────────────────────────

// ─── HTTP Commands ───────────────────────────────────────────────────────────

// ─── Database Commands ───────────────────────────────────────────────────────

// ─── Event Commands ──────────────────────────────────────────────────────────

// ─── Mail & Notification Commands ────────────────────────────────────────────

// ─── Validation & Authorization Commands ────────────────────────────────────

// ─── Testing Command ─────────────────────────────────────────────────────────

// ─── Configuration Command ──────────────────────────────────────────────────

// ─── WordPress Commands ─────────────────────────────────────────────────────

// ─── Assets ──────────────────────────────────────────────────────────────────

$application = new Application();

$application->addCommands( [
    // ─── Foundation ──────────────────────────────────────────────────────────
        new MakeProviderCommand(),
        new MakeJobCommand(),
        new MakeServiceCommand(),
        new MakeTraitCommand(),
