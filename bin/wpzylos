    // ─── Mail & Notifications ────────────────────────────────────────────────
        new MakeMailCommand(),
        new MakeNotificationCommand(),

    // ─── Validation & Authorization ──────────────────────────────────────────
        new MakeRuleCommand(),
        new MakePolicyCommand(),

    // ─── Testing ─────────────────────────────────────────────────────────────
        new MakeTestCommand(),

    // ─── Configuration ───────────────────────────────────────────────────────
        new MakeConfigCommand(),

    // ─── WordPress ───────────────────────────────────────────────────────────
        new MakePostTypeCommand(),
        new MakeTaxonomyCommand(),
        new MakeMetaboxCommand(),
        new MakeMenuCommand(),
        new MakeSettingsCommand(),
        new MakeWidgetCommand(),
        new MakeShortcodeCommand(),
        new MakeBlockCommand(),
        new MakeColumnsCommand(),
        new MakeActionCommand(),
        new MakeFilterCommand(),

    // ─── Assets ──────────────────────────────────────────────────────────────
        new MakeAssetCommand(),
] );

$application->run();
